{
  "name": "@bjalon/deck-runtime",
  "version": "1.1.0",
  "private": false,
  "type": "module",
  "description": "Runtime React pour compiler, afficher et editer des decks YAML/Markdown.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bjalon/qastia-deck.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/deck-runtime.js",
  "module": "./dist/deck-runtime.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/deck-runtime.js"
    },
    "./viewer": {
      "types": "./dist/types/viewer.d.ts",
      "import": "./dist/viewer.js"
    },
    "./studio": {
      "types": "./dist/types/studio.d.ts",
      "import": "./dist/studio.js"
    },
    "./presentation": {
      "types": "./dist/types/presentation.d.ts",
      "import": "./dist/presentation.js"
    },
    "./compiler": {
      "types": "./dist/types/compiler.d.ts",
      "import": "./dist/compiler.js"
    },
    "./runtime": {
      "types": "./dist/types/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./pdf": {
      "types": "./dist/types/pdf.d.ts",
      "import": "./dist/pdf.js"
    },
    "./styles.css": "./dist/deck-runtime.css"
  },
  "sideEffects": [
    "*.css",
    "./dist/deck-runtime.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:example": "vite build --config vite.example.config.ts",
    "dev:example": "vite --config vite.example.config.ts --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:jest": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.3",
    "@hookform/resolvers": "^3.10.0",
    "react-hook-form": "^7.56.2",
    "react-markdown": "^9.0.3",
    "unified": "^11.0.5",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "html2canvas": "^1.4.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jspdf": "^4.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.2"
  }
}
