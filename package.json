{
  "name": "@qastia/deck-runtime",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Runtime React pour compiler, afficher et editer des decks YAML/Markdown.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bjalon/qastia-deck.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/deck-runtime.js",
  "module": "./dist/deck-runtime.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/deck-runtime.js"
    },
    "./styles.css": "./dist/deck-runtime.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.3",
    "@hookform/resolvers": "^3.10.0",
    "mermaid": "^11.6.0",
    "react-hook-form": "^7.56.2",
    "react-markdown": "^9.0.3",
    "unified": "^11.0.5",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "typescript": "^5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.2"
  }
}
